      "allowed_output_modes": ["raw_lua", "json_wrapper"],
      "primary_output_mode": "raw_lua",
      "expected_outputs": { "raw_lua": "return wf.vars.phoneNumbers[#wf.vars.phoneNumbers]" },
      "input_roots": ["wf.vars.phoneNumbers"],
