    {
      "id": "synthetic-case-09-phones-to-array",
      "title": "Телефоны в массив",
      "prompt": "Сделай так, чтобы phones всегда был массивом.",
      "context": { "wf": { "vars": { "customer": { "phones": { "mobile": "+10000000001" } } } } },
      "archetype": "normalization",
      "allowed_output_modes": ["raw_lua", "json_wrapper"],
      "primary_output_mode": "raw_lua",
      "expected_outputs": { "raw_lua": "local phones = wf.vars.customer.phones\nif type(phones) ~= \"table\" then\n  return {phones}\nend\n\nlocal is_array = true\nfor key, _ in pairs(phones) do\n  if type(key) ~= \"number\" then\n    is_array = false\n    break\n  end\nend\n\nreturn is_array and phones or {phones}" },
      "input_roots": ["wf.vars.customer.phones"],
      "risk_tags": ["array_semantics", "type_normalization"],
      "source_ref": "synthetic_benchmark:9"
    },
