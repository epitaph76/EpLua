# Baseline environment for LocalScript Agent.
# Final runtime values will be confirmed in later stages.

PROJECT_NAME=localscript-agent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=256
OLLAMA_BATCH=1
OLLAMA_PARALLEL=1
OLLAMA_GPU_ONLY=true
GPU_VRAM_BUDGET_GB=8

ENABLE_EXTERNAL_AI=false
ENABLE_LOCAL_RETRIEVAL=false
ENABLE_UI=false

LOG_LEVEL=INFO
